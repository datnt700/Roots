# ═══════════════════════════════════════════════════════════════════
# .env — server-side secrets (gitignored, never commit)
# Read by Prisma CLI + Next.js server runtime
# Copy this file and fill in real values before running the app
# ═══════════════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ────────────────────────────────────
# Get from: https://console.neon.tech → Project → Connection Details
DATABASE_URL="postgresql://neondb_owner:npg_ikEz2osu6yaf@ep-red-cell-alpx366n-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# ── Field-level Encryption (GDPR Art.32 + Decree 13/2023 Art.26) ─
# Generate both with:  openssl rand -hex 32
ENCRYPTION_KEY="replace_with_64_char_hex_string"
EMAIL_HASH_PEPPER="replace_with_64_char_hex_string"

# ── Auth.js ───────────────────────────────────────────────────────
# Generate with:  npx auth secret
AUTH_SECRET="replace_with_auth_secret"

# OAuth — Google
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# OAuth — Facebook
# Get from: https://developers.facebook.com → My Apps → App Settings
AUTH_FACEBOOK_ID="your-facebook-app-id"
AUTH_FACEBOOK_SECRET="your-facebook-app-secret"

# OAuth — Apple
# Get from: https://developer.apple.com → Certificates, Identifiers & Profiles
AUTH_APPLE_ID="your-apple-services-id"
AUTH_APPLE_SECRET="your-apple-private-key-base64"

# ── OpenAI (Whisper transcription) ────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ── Anthropic Claude (AI summarization + tagging) ─────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# ── AWS S3 (file storage) ─────────────────────────────────────────
# Get from: https://console.aws.amazon.com → IAM → Users → Security credentials
AWS_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID="your-iam-access-key-id"
AWS_SECRET_ACCESS_KEY="your-iam-secret-access-key"
S3_BUCKET="your-bucket-name"