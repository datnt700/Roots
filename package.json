{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "db:init": "node scripts/init-db.mjs",
    "db:init:dev": "node scripts/init-db.mjs --env=development",
    "db:init:prod": "node scripts/init-db.mjs --env=production",
    "lint": "eslint .",
