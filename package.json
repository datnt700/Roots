    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-slot": "1.2.4",
    "@vercel/analytics": "1.6.1",
    "bcryptjs": "^3.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.564.0",
    "next": "16.2.0",
    "next-auth": "5.0.0-beta.31",
